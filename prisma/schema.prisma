generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String         @id @default(uuid())
  name                    String?
  phone                   String         @unique
  image                   String?
  role                    Role           @default(CUSTOMER)
  profileCompleted        Boolean        @default(false)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  password                String?
  telegramUsername        String?
  preferredContactChannel ContactChannel @default(PHONE)
  addresses               Address[]
  carts                   Cart[]
  orders                  Order[]
  staffProfiles           StaffProfile[]
}

model Shop {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  description      String?
  heroTitle        String?
  heroSubtitle     String?
  heroImageUrl     String?
  status           ShopStatus     @default(ACTIVE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  whatsappPhone    String?
  telegramUsername String?
  shopType         ShopType       @default(PRODUCT)
  checkoutMode     CheckoutMode   @default(DELIVERY)
  themePrimary     String?
  themeSecondary   String?
  themeAccent      String?
  themeSurface     String?
  logoUrl          String?
  homepageVariant  String?
  carts            Cart[]
  categories       Category[]
  orders           Order[]
  products         Product[]
  staffProfiles    StaffProfile[]
}

model StaffProfile {
  id        String   @id @default(uuid())
  userId    String
  shopId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId, isActive])
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  label     String?
  recipient String
  phone     String
  street    String
  city      String
  state     String
  postcode  String
  country   String   @default("Malaysia")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  shopId    String
  updatedAt DateTime  @updatedAt
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([shopId, name])
  @@index([shopId])
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  imageUrl    String?
  status      Boolean     @default(true)
  categoryId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  attributes  Json?
  shopId      String
  itemType    ItemType    @default(PHYSICAL)
  fulfillmentType FulfillmentType @default(DELIVERY)
  requiresScheduling Boolean @default(false)
  durationMinutes Int?
  minAdvanceHours Int?
  maxAdvanceDays Int?
  requiresAddress Boolean @default(true)
  requiresContact Boolean @default(true)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  category    Category    @relation(fields: [categoryId], references: [id])
  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([shopId, categoryId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shopId    String
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([userId, shopId])
  @@index([shopId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                      String         @id @default(uuid())
  userId                  String?
  guestSession            String?
  status                  OrderStatus    @default(PENDING)
  totalAmount             Decimal        @db.Decimal(10, 2)
  flowType                OrderFlowType  @default(DELIVERY)
  customerName            String?
  customerPhone           String?
  notes                   String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  addressId               String?
  deliveryCity            String?
  deliveryCountry         String?
  deliveryPhone           String?
  deliveryPostcode        String?
  deliveryRecipient       String?
  deliveryState           String?
  deliveryStreet          String?
  telegramUsername        String?
  preferredContactChannel ContactChannel @default(PHONE)
  scheduledDate           DateTime?
  scheduledStartTime      DateTime?
  scheduledEndTime        DateTime?
  serviceLocationType     ServiceLocationType?
  serviceAddressText      String?
  bookingReference        String?
  shopId                  String
  address                 Address?       @relation(fields: [addressId], references: [id])
  shop                    Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user                    User?          @relation(fields: [userId], references: [id])
  items                   OrderItem[]

  @@index([shopId, status])
  @@index([userId, createdAt])
}

model OrderItem {
  id              String           @id @default(uuid())
  orderId         String
  productId       String
  quantity        Int
  unitPrice       Decimal          @db.Decimal(10, 2)
  itemType        ItemType?
  fulfillmentType FulfillmentType?
  scheduledDate   DateTime?
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DONE
  CANCELLED
}

enum ContactChannel {
  PHONE
  TELEGRAM
}

enum ShopStatus {
  ACTIVE
  INACTIVE
}

enum ShopType {
  PRODUCT
  SERVICE
  HYBRID
}

enum CheckoutMode {
  DELIVERY
  BOOKING
  FLEXIBLE
}

enum ItemType {
  PHYSICAL
  SERVICE
}

enum FulfillmentType {
  DELIVERY
  PICKUP
  BOOKING
}

enum OrderFlowType {
  DELIVERY
  PICKUP
  BOOKING
}

enum ServiceLocationType {
  ONSITE
  CUSTOMER_PLACE
  ONLINE
}
